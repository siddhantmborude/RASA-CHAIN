PORT=5000
MONGODB_URI=mongodb://localhost:27017/rasa-chain
JWT_SECRET=rasa_chain_super_secret_jwt_key_2024
JWT_EXPIRE=7d
NODE_ENV=development

# Blockchain Configuration (Polygon/Ethereum)
BLOCKCHAIN_PROVIDER=simulated
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=your_private_key_here
CONTRACT_ADDRESS=your_contract_address_here

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Client URL
CLIENT_URL=https://rasa-chain-frontend.vercel.app

# Socket.IO
SOCKET_CORS_ORIGIN=https://rasa-chain-frontend.vercel.app
